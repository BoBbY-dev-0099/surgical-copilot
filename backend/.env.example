# Surgical Copilot Environment Configuration
# Copy this file to .env and update with your values

# ============================================
# CORE CONFIGURATION
# ============================================

# Demo mode - set to true to use mock responses (no GPU required)
DEMO_MODE=true

# Hugging Face token for model access (required for real inference)
HF_TOKEN=your_huggingface_token_here

# ============================================
# MODEL CONFIGURATION
# ============================================

# MedGemma model identifiers
MODEL_ID=google/medgemma-27b-text-it
MODEL_4B_ID=google/medgemma-4b-it

# Device configuration (auto, cuda, cpu)
DEVICE=auto

# ============================================
# ADAPTER PATHS (for LoRA fine-tuned models)
# ============================================

# These paths should point to your LoRA adapter directories
# Each adapter directory should contain adapter_config.json and adapter_model.safetensors
ADAPTER_PHASE1B_PATH=/path/to/adapter/phase1b
ADAPTER_PHASE2_PATH=/path/to/adapter/phase2
ADAPTER_ONCO_PATH=/path/to/adapter/onco

# ============================================
# API CONFIGURATION
# ============================================

# API server settings
API_HOST=0.0.0.0
API_PORT=8000

# ============================================
# PERFORMANCE SETTINGS
# ============================================

# Timeout settings (in seconds)
INFER_TIMEOUT_SECONDS=120
ENRICH_TIMEOUT_SECONDS=90

# Auto-fallback to demo mode on inference failure
AUTO_FALLBACK_TO_DEMO=false

# ============================================
# LOGGING
# ============================================

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# ============================================
# OPTIONAL: AWS S3 Configuration (for adapter downloads)
# ============================================

# S3_BUCKET=your-bucket-name
# S3_PREFIX=adapters/
# AWS_REGION=us-east-1

# ============================================
# OPTIONAL: Memory Optimization
# ============================================

# PyTorch CUDA memory configuration
# TORCH_CUDA_ALLOC_CONF=expandable_segments:True